# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
DEFAULT_PROVIDER=ollama
LOCAL_MODEL_PATH=./src/models/Phi-3-mini-4k-instruct-q4.gguf

# LAB CONFIG
# Options: openai | google | local | ollama
# DEFAULT_PROVIDER=openai
# DEFAULT_MODEL=gpt-4o
LOG_LEVEL=INFO

# OLLAMA SETTINGS (local gguf imported via Modelfile)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3-local

TAVILY_API_KEY = tvly-dev-api-key
